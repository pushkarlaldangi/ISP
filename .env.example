# Copy this file to .env.local and fill in real values for development.
# Never commit .env.local or any file containing real secrets.

# ---------- Public (exposed to the browser bundle) ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — create a project at https://supabase.com and copy from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (optional during dev — leave blank and Sentry is a no-op)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (optional during dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---------- Server-only ----------
# Supabase Postgres connection string (Project Settings → Database → Connection string).
# Use the "Transaction Pooler" connection string for the app at runtime.
# Use the "Session Pooler" or direct connection for drizzle migrations.
DATABASE_URL=

# Service-role key for privileged server-side operations (cron, admin)
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis REST — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (transactional email) — https://resend.com
RESEND_API_KEY=

# Sentry server DSN (same as public DSN is fine; can also be different project)
SENTRY_DSN=

# 32+ char random secret used to encrypt PII columns at the application layer.
# Generate via: openssl rand -base64 48
PII_ENCRYPTION_KEY=

# Secret token used to authenticate Vercel cron callbacks.
# Generate via: openssl rand -hex 32
CRON_SECRET=
